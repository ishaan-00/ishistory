---
import Base from '../layouts/Base.astro';
import Cosmos from '../components/Cosmos.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { series } from '../data/series.js';
---
<Base
  title="ishistory — The History Behind the Ideas"
  description="Three deep-dive series tracing the history of AI, robotics, and the internet. Long-form history for curious people."
>
<Cosmos />
<Nav />

<section class="hero">
  <div class="hero-bg-glyph" aria-hidden="true">∞</div>
  <div class="hero-content">
    <p class="hero-eyebrow">ishistory — Long-form History</p>
    <h1 class="hero-title">
      The history<br/>
      <em>behind the ideas</em>
    </h1>
    <p class="hero-sub">Three Series · Ongoing</p>
    <p class="hero-tagline">
      Science, technology, and the people who shaped the world we inherited.
    </p>
    <div class="hero-cta">
      <a href="#series" class="btn btn-primary">Explore Series</a>
      <a href="/search/" class="btn btn-secondary">Search Episodes</a>
    </div>
  </div>
  <div class="hero-scroll-hint" aria-hidden="true">
    <span class="hero-scroll-line"></span>
    <span class="hero-scroll-label">scroll</span>
  </div>
</section>

<div class="divider" style="margin:0">
  <div class="divider-line"></div>
  <div class="divider-sym">✦</div>
  <div class="divider-line"></div>
</div>

<section class="series-intro">
  <p class="section-label">Three series</p>
  <p class="series-intro-text">
    Long-form explorations of the ideas that changed everything —<br/>
    told with the depth they deserve.
  </p>
</section>

<section class="series-grid" id="series">
  {Object.entries(series).map(([key, s], i) => (
    <a href={`/${key}/`} class="series-card" style={`--c: ${s.color}; --i: ${i}`}>
      <div class="series-card-inner">
        <div class="series-card-top">
          <div class="series-card-glyph">{s.glyph}</div>
          {s.status === 'complete' && (
            <span class="series-card-badge">Complete</span>
          )}
        </div>
        <div class="series-card-body">
          <div class="series-card-label">ishistory Series</div>
          <div class="series-card-title">{s.label}</div>
          <p class="series-card-desc">{s.description}</p>
        </div>
        <div class="series-card-footer">
          <span class="series-card-cta">
            Read series
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </div>
      <div class="series-card-accent" aria-hidden="true"></div>
    </a>
  ))}
</section>

<Footer />
</Base>

<style>
/* ── Hero ──────────────────────────────────────────────────────────── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: calc(var(--nav-h) + 5rem) 3rem 6rem;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.hero-bg-glyph {
  position: absolute;
  right: -1%;
  top: 50%;
  transform: translateY(-48%);
  font-family: var(--font-serif);
  font-size: clamp(16rem, 24vw, 30rem);
  font-weight: 700;
  font-style: italic;
  color: transparent;
  -webkit-text-stroke: 1px rgba(200, 151, 58, 0.05);
  line-height: 1;
  pointer-events: none;
  user-select: none;
  letter-spacing: -0.04em;
}

.hero-content {
  position: relative;
  max-width: 700px;
}

.hero-eyebrow {
  font-family: var(--font-sans);
  font-size: 0.62rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--ember);
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 1.2rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.2s ease forwards;
}
.hero-eyebrow::before {
  content: '';
  width: 28px;
  height: 1px;
  background: var(--ember);
  opacity: 0.6;
  flex-shrink: 0;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(3.4rem, 9vw, 7.5rem);
  font-weight: 700;
  line-height: 0.9;
  letter-spacing: -0.03em;
  color: var(--cream);
  margin-bottom: 1.8rem;
  opacity: 0;
  animation: fadeUp 1s 0.35s ease forwards;
}
.hero-title em {
  font-style: italic;
  font-weight: 300;
  color: var(--amber);
  display: block;
}

.hero-sub {
  font-family: var(--font-sans);
  font-size: 0.58rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--fog);
  border: 1px solid var(--border);
  display: inline-block;
  padding: 0.32rem 0.9rem;
  margin-bottom: 1.6rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.5s ease forwards;
}

.hero-tagline {
  font-family: var(--font-body);
  font-size: 1.25rem;
  line-height: 1.8;
  color: var(--fog);
  max-width: 46ch;
  font-style: italic;
  margin-bottom: 2.8rem;
  opacity: 0;
  animation: fadeUp 0.9s 0.6s ease forwards;
}

.hero-cta {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.9s 0.72s ease forwards;
}

.hero-scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  opacity: 0;
  animation: fadeIn 1s 1.4s ease forwards;
}
.hero-scroll-line {
  width: 1px;
  height: 36px;
  background: linear-gradient(to bottom, var(--border), transparent);
}
.hero-scroll-label {
  font-family: var(--font-sans);
  font-size: 0.48rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--dust);
}

/* ── Series intro ──────────────────────────────────────────────────── */
.series-intro {
  padding: 5rem 3rem 3.5rem;
  max-width: 720px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.series-intro .section-label {
  margin-bottom: 1.5rem;
}

.series-intro-text {
  font-family: var(--font-serif);
  font-size: clamp(1.3rem, 2.5vw, 1.75rem);
  font-weight: 300;
  line-height: 1.75;
  color: var(--linen);
  font-style: italic;
  max-width: 100%;
}

/* ── Series grid ───────────────────────────────────────────────────── */
.series-grid {
  padding: 1rem 2rem 8rem;
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border-dim);
  position: relative;
  z-index: 1;
}

.series-card {
  text-decoration: none;
  color: inherit;
  background: var(--ink);
  position: relative;
  overflow: hidden;
  transition: background var(--t-base);
  opacity: 0;
  animation: fadeUp 0.8s calc(0.1s * var(--i, 0) + 0.2s) ease forwards;
}
.series-card:hover { background: var(--deep); }

.series-card-inner {
  padding: 2.6rem 2.2rem 2.2rem;
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  height: 100%;
  position: relative;
  z-index: 1;
}

/* Left accent bar */
.series-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: var(--c, var(--amber));
  transform: scaleY(0);
  transform-origin: bottom;
  transition: transform 0.35s ease;
}
.series-card:hover::before { transform: scaleY(1); }

/* Subtle top glow on hover */
.series-card-accent {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 120px;
  background: radial-gradient(ellipse at top, rgba(200,151,58,0.05) 0%, transparent 70%);
  opacity: 0;
  transition: opacity var(--t-slow);
  pointer-events: none;
}
.series-card:hover .series-card-accent { opacity: 1; }

.series-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.series-card-glyph {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.22em;
  color: var(--c, var(--amber));
  opacity: 0.55;
  transition: opacity var(--t-base);
}
.series-card:hover .series-card-glyph { opacity: 0.9; }

.series-card-badge {
  font-family: var(--font-sans);
  font-size: 0.5rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  background: rgba(200, 151, 58, 0.1);
  color: var(--amber);
  padding: 0.22rem 0.55rem;
  border-radius: 1px;
  border: 1px solid rgba(200, 151, 58, 0.15);
}

.series-card-body { flex: 1; }

.series-card-label {
  font-family: var(--font-sans);
  font-size: 0.54rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ember);
  margin-bottom: 0.7rem;
  opacity: 0.7;
}

.series-card-title {
  font-family: var(--font-serif);
  font-size: 1.35rem;
  font-weight: 700;
  font-style: italic;
  color: var(--cream);
  margin-bottom: 0.75rem;
  line-height: 1.15;
  transition: color var(--t-fast);
}
.series-card:hover .series-card-title { color: var(--c, var(--amber)); }

.series-card-desc {
  font-family: var(--font-body);
  font-size: 0.97rem;
  line-height: 1.7;
  color: var(--fog);
}

.series-card-footer {
  padding-top: 0.5rem;
  border-top: 1px solid var(--border-dim);
  transition: border-color var(--t-base);
}
.series-card:hover .series-card-footer { border-color: var(--border); }

.series-card-cta {
  font-family: var(--font-sans);
  font-size: 0.56rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--dust);
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: color var(--t-fast), gap var(--t-base);
}
.series-card:hover .series-card-cta {
  color: var(--amber);
  gap: 0.75rem;
}

/* ── Responsive ────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .series-grid { grid-template-columns: 1fr; padding: 0 1.5rem 5rem; }
  .series-card { animation: none; opacity: 1; }
}

@media (max-width: 768px) {
  .hero { padding: calc(var(--nav-h) + 3rem) 1.5rem 5rem; }
  .hero-bg-glyph { font-size: clamp(10rem, 30vw, 18rem); right: -5%; opacity: 0.7; }
  .hero-scroll-hint { display: none; }
  .series-intro { padding: 3rem 1.5rem 2rem; }
  .series-intro-text { font-size: 1.2rem; }
}
</style>
