---
import Base from '../layouts/Base.astro';
import Cosmos from '../components/Cosmos.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { series } from '../data/series.js';
---
<Base
  title="ishistory — The History Behind the Ideas"
  description="Three deep-dive series tracing the history of AI, robotics, and the internet. Long-form history for curious people."
>
<Cosmos />
<Nav />
<section class="hero">
  <div class="hero-bg-glyph" aria-hidden="true">∞</div>
  <div class="hero-content">
    <p class="hero-eyebrow">ishistory — Long-form History</p>
    <h1 class="hero-title">The history<br/><em>behind the ideas</em></h1>
    <p class="hero-sub">Three Series · Ongoing</p>
    <p class="hero-tagline">Science, technology, and the people who shaped the world we inherited.</p>
    <div class="hero-cta">
      <a href="#series" class="btn btn-primary">Explore Series</a>
      <a href="/search/" class="btn btn-secondary">Search Episodes</a>
    </div>
  </div>
</section>
<div class="divider" style="margin:0"><div class="divider-line"></div><div class="divider-sym">✦</div><div class="divider-line"></div></div>
<section class="series-intro">
  <p>Three long-form series exploring the ideas that changed everything — told with the depth they deserve.</p>
</section>
<section class="series-grid" id="series">
  {Object.entries(series).map(([key, s]) => (
    <a href={`/${key}/`} class="series-card" style={`--c: ${s.color}`}>
      <div class="series-card-glyph">{s.glyph}</div>
      <div class="series-card-body">
        <div class="series-card-label">ishistory Series</div>
        <div class="series-card-title">{s.label}</div>
        <p class="series-card-desc">{s.description}</p>
        {s.status === 'complete' && <span class="series-card-badge">Complete</span>}
      </div>
      <div class="series-card-arrow">→</div>
    </a>
  ))}
</section>
<Footer />
</Base>
<style>
.hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 10rem 3rem 6rem; position: relative; z-index: 1; overflow: hidden; }
.hero-bg-glyph { position: absolute; right: 3%; top: 50%; transform: translateY(-48%); font-family: var(--font-serif); font-size: clamp(14rem,22vw,26rem); font-weight: 700; font-style: italic; color: transparent; -webkit-text-stroke: 1px rgba(200,151,58,0.06); line-height: 1; pointer-events: none; user-select: none; }
.hero-content { position: relative; max-width: 680px; }
.hero-eyebrow { font-family: var(--font-sans); font-size: 0.6rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--ember); margin-bottom: 1.8rem; display: flex; align-items: center; gap: 1.2rem; opacity: 0; animation: fadeUp 0.8s 0.2s ease forwards; }
.hero-eyebrow::before { content: ""; width: 26px; height: 1px; background: var(--ember); opacity: 0.7; flex-shrink: 0; }
.hero-title { font-family: var(--font-serif); font-size: clamp(3.2rem,8vw,7rem); font-weight: 700; line-height: 0.92; letter-spacing: -0.025em; color: var(--cream); margin-bottom: 1.6rem; opacity: 0; animation: fadeUp 1s 0.35s ease forwards; }
.hero-title em { font-style: italic; font-weight: 400; color: var(--amber); }
.hero-sub { font-family: var(--font-sans); font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--fog); border: 1px solid var(--border); display: inline-block; padding: 0.3rem 0.9rem; margin-bottom: 1.4rem; opacity: 0; animation: fadeUp 0.8s 0.5s ease forwards; }
.hero-tagline { font-family: var(--font-body); font-size: 1.2rem; line-height: 1.85; color: var(--linen); max-width: 480px; font-style: italic; margin-bottom: 2.6rem; opacity: 0; animation: fadeUp 0.9s 0.6s ease forwards; }
.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.9s 0.72s ease forwards; }
.series-intro { padding: 5rem 3rem; max-width: 800px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
.series-intro p { font-family: var(--font-serif); font-size: clamp(1.2rem,2.2vw,1.6rem); font-weight: 300; line-height: 1.9; color: var(--linen); font-style: italic; }
.series-grid { padding: 0 3rem 8rem; max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit,minmax(280px,1fr)); gap: 1px; position: relative; z-index: 1; }
.series-card { padding: 2.8rem 2.4rem; border: 1px solid var(--border-dim); text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 1.4rem; background: rgba(13,17,23,0.6); transition: background 0.25s, border-color 0.25s; position: relative; overflow: hidden; }
.series-card::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--c, var(--amber)); transform: scaleY(0); transform-origin: bottom; transition: transform 0.32s ease; }
.series-card:hover { background: rgba(22,28,38,0.9); border-color: var(--border); }
.series-card:hover::before { transform: scaleY(1); }
.series-card-glyph { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.2em; color: var(--c,var(--amber)); opacity: 0.6; }
.series-card-body { flex: 1; }
.series-card-label { font-family: var(--font-sans); font-size: 0.56rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ember); margin-bottom: 0.6rem; opacity: 0.75; }
.series-card-title { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 700; font-style: italic; color: var(--cream); margin-bottom: 0.65rem; line-height: 1.2; transition: color 0.2s; }
.series-card:hover .series-card-title { color: var(--amber); }
.series-card-desc { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.7; color: var(--fog); }
.series-card-badge { display: inline-block; margin-top: 0.8rem; font-family: var(--font-sans); font-size: 0.52rem; letter-spacing: 0.15em; text-transform: uppercase; background: rgba(200,151,58,0.1); color: var(--amber); padding: 0.2rem 0.6rem; border-radius: 2px; }
.series-card-arrow { font-size: 0.9rem; color: rgba(200,151,58,0.2); align-self: flex-end; transition: color 0.2s, transform 0.2s; }
.series-card:hover .series-card-arrow { color: var(--amber); transform: translateX(4px); }
@media (max-width: 768px) { .hero { padding: 8rem 1.5rem 5rem; } .series-grid { padding: 0 1.5rem 5rem; grid-template-columns: 1fr; } .series-intro { padding: 3rem 1.5rem; } }
</style>