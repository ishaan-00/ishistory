---
import Base from '../../layouts/Base.astro';
import Cosmos from '../../components/Cosmos.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { series as allSeries } from '../../data/series.js';

export async function getStaticPaths() {
  const allContent = await Astro.glob('../../content/**/*.md');
  return allContent
    .filter(p => p.frontmatter.series && !p.frontmatter.draft)
    .map(page => {
      const slug = page.file.split('/').pop().replace('.md', '');
      return { params: { seriesKey: page.frontmatter.series, slug }, props: { page } };
    });
}

const { seriesKey, slug } = Astro.params;
const { page } = Astro.props;
const fm = page.frontmatter;
const s  = allSeries[seriesKey];
const { Content } = page;

const allContent = await Astro.glob('../../content/**/*.md');
const sorted = allContent
  .filter(p => p.frontmatter.series === seriesKey && !p.frontmatter.draft)
  .sort((a, b) => (a.frontmatter.episode_number ?? 999) - (b.frontmatter.episode_number ?? 999));

const idx     = sorted.findIndex(p => p.file.split('/').pop()?.replace('.md','') === slug);
const prev    = idx > 0 ? sorted[idx - 1] : null;
const next    = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const prevSlug = prev?.file.split('/').pop()?.replace('.md','');
const nextSlug = next?.file.split('/').pop()?.replace('.md','');
const prevUrl  = prev ? `/${seriesKey}/${prevSlug}/` : undefined;
const nextUrl  = next ? `/${seriesKey}/${nextSlug}/` : undefined;

const related = sorted
  .filter(p => p.file.split('/').pop()?.replace('.md','') !== slug && p.frontmatter.part_label === fm.part_label)
  .slice(0, 3);

const raw      = typeof page.rawContent === 'function' ? page.rawContent() : '';
const words    = raw.trim().split(/\s+/).length;
const readTime = Math.max(1, Math.round(words / 230));
const dateStr  = fm.date ? new Date(fm.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : null;
const siteUrl  = 'https://ishistory.pages.dev';
const canonical = `${siteUrl}/${seriesKey}/${slug}/`;

const articleLd = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: fm.title, description: fm.description ?? '',
  datePublished: fm.date ? String(fm.date) : undefined,
  author: { '@type': 'Person', name: 'Ishaan' },
  publisher: { '@type': 'Organization', name: 'ishistory', url: siteUrl },
  url: canonical, isPartOf: { '@type': 'CreativeWorkSeries', name: s.label },
};
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ishistory', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: s.label, item: `${siteUrl}/${seriesKey}/` },
    { '@type': 'ListItem', position: 3, name: fm.title, item: canonical },
  ],
};
---
<Base
  title={`${fm.title} — ishistory`}
  description={fm.description ?? ''}
  ogType="article"
  publishedTime={fm.date ? String(fm.date) : undefined}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}></script>
</Fragment>

<div id="progress-bar"></div>
<Cosmos />
<Nav backLink={{ href: `/${seriesKey}/`, label: s.shortLabel }} />

<section class="ep-hero">
  <div class="ep-hero-numeral" aria-hidden="true">{fm.roman}</div>
  <div class="ep-hero-inner">
    <div class="ep-meta">
      {fm.roman && <span class="ep-episode">Episode {fm.roman}</span>}
      {fm.roman && <span class="ep-sep">·</span>}
      {fm.tag   && <span class="ep-tag">{fm.tag}</span>}
      {dateStr  && <span class="ep-date">{dateStr}</span>}
      <span class="ep-time">{readTime} min read</span>
    </div>
    <h1 class="ep-title">{fm.title}</h1>
    {fm.description && <p class="ep-desc">{fm.description}</p>}
    {fm.part_label  && <div class="ep-part">{fm.part_label}</div>}
    <div class="ep-actions">
      <button class="share-btn" id="shareBtn">Share Episode</button>
    </div>
  </div>
</section>

<div class="ep-reading-bar">
  <span class="ep-reading-series">{s.label}</span>
  <span id="reading-pct">0%</span>
</div>

<div class="ep-toc-wrap" id="tocWrap" style="display:none">
  <button class="ep-toc-toggle" id="tocToggle">
    <span class="ep-toc-label">Contents</span>
    <span class="ep-toc-caret">↓</span>
  </button>
  <ul class="ep-toc-list" id="tocList"></ul>
</div>

<div class="ep-layout">
  <article class="ep-article" id="epArticle">
    <Content />
  </article>
</div>

{related.length > 0 && (
  <div class="ep-related">
    <p class="ep-related-label">Also in this part</p>
    <div class="ep-related-grid">
      {related.map(r => {
        const rSlug = r.file.split('/').pop()?.replace('.md','');
        const rWords = typeof r.rawContent === 'function' ? r.rawContent().trim().split(/\s+/).length : 0;
        const rTime  = Math.max(1, Math.round(rWords / 230));
        return (
          <a href={`/${seriesKey}/${rSlug}/`} class="ep-related-card">
            <div class="ep-related-roman">{r.frontmatter.roman}</div>
            <div class="ep-related-tag">{r.frontmatter.tag ?? 'Episode'}</div>
            <div class="ep-related-title">{r.frontmatter.title}</div>
            <div class="ep-related-time">{rTime} min</div>
          </a>
        );
      })}
    </div>
  </div>
)}

<nav class="ep-nav">
  {prev ? (
    <a href={prevUrl} class="ep-nav-btn prev">
      <span class="ep-nav-dir">← Previous</span>
      <span class="ep-nav-title">{prev.frontmatter.title}</span>
    </a>
  ) : <div></div>}
  {next ? (
    <a href={nextUrl} class="ep-nav-btn next">
      <span class="ep-nav-dir">Next →</span>
      <span class="ep-nav-title">{next.frontmatter.title}</span>
    </a>
  ) : <div></div>}
</nav>

<Footer />
<button id="backToTop" aria-label="Back to top">↑</button>

<script define:vars={{ prevUrl, nextUrl, slug, seriesKey }}>
  // Progress bar
  const bar     = document.getElementById('progress-bar');
  const pct     = document.getElementById('reading-pct');
  const article = document.getElementById('epArticle');
  const top     = document.getElementById('backToTop');

  window.addEventListener('scroll', () => {
    if (!article) return;
    const rect = article.getBoundingClientRect();
    const total = article.offsetHeight - window.innerHeight;
    const p = Math.round(Math.max(0, Math.min(1, -rect.top / total)) * 100);
    if (bar) bar.style.width = p + '%';
    if (pct) pct.textContent = p + '%';
    if (top) top.classList.toggle('visible', window.scrollY > 500);
  }, { passive: true });

  top?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // Mark as read
  localStorage.setItem(`read:${seriesKey}:${slug}`, '1');

  // TOC
  const headings = article?.querySelectorAll('h2, h3');
  const tocWrap  = document.getElementById('tocWrap');
  const tocList  = document.getElementById('tocList');
  const tocToggle = document.getElementById('tocToggle');

  if (headings && headings.length >= 3 && tocWrap && tocList) {
    tocWrap.style.display = 'block';
    headings.forEach((h, i) => {
      if (!h.id) h.id = `h-${i}`;
      const li = document.createElement('li');
      if (h.tagName === 'H3') li.classList.add('toc-h3');
      const a = document.createElement('a');
      a.href = `#${h.id}`; a.textContent = h.textContent ?? '';
      a.addEventListener('click', e => {
        e.preventDefault();
        h.scrollIntoView({ behavior: 'smooth', block: 'start' });
        tocWrap.classList.remove('open');
      });
      li.appendChild(a); tocList.appendChild(li);
    });
    tocToggle?.addEventListener('click', () => tocWrap.classList.toggle('open'));
  }

  // Share
  document.getElementById('shareBtn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href).then(() => {
      const btn = document.getElementById('shareBtn');
      if (!btn) return;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Share Episode'; }, 2000);
    });
  });

  // Keyboard nav
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft'  && prevUrl) window.location.href = prevUrl;
    if (e.key === 'ArrowRight' && nextUrl) window.location.href = nextUrl;
  });
</script>
</Base>

<style>
#progress-bar {
  position: fixed; top: 0; left: 0; height: 2px;
  background: var(--amber); width: 0%; z-index: 200;
  transition: width 0.1s linear;
  box-shadow: 0 0 8px rgba(200,151,58,0.5);
}
.ep-hero {
  padding: 7rem 3rem 4rem;
  background: linear-gradient(160deg, #080d14 0%, #0f1520 60%, #080a0e 100%);
  position: relative; overflow: hidden; z-index: 1;
  border-bottom: 1px solid var(--border-dim);
}
.ep-hero::before {
  content: '; position: absolute; inset: 0;
  background: radial-gradient(ellipse 55% 65% at 80% 50%, rgba(200,151,58,0.055) 0%, transparent 60%);
}
.ep-hero-numeral {
  position: absolute; right: 3%; top: 50%; transform: translateY(-50%);
  font-family: var(--font-serif); font-size: clamp(9rem,15vw,17rem);
  font-weight: 300; color: rgba(200,151,58,0.04);
  line-height: 1; pointer-events: none; user-select: none;
}
.ep-hero-inner {
  position: relative; max-width: 760px;
  opacity: 0; animation: fadeUp 0.8s 0.1s ease forwards;
}
.ep-meta {
  display: flex; align-items: center; gap: 1rem;
  margin-bottom: 1.4rem; flex-wrap: wrap;
}
.ep-episode { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber); }
.ep-sep { color: var(--border); }
.ep-tag { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--fog); background: rgba(200,151,58,0.08); padding: 0.2rem 0.65rem; }
.ep-date { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em; color: var(--fog); }
.ep-time { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em; color: var(--muted); }
.ep-title {
  font-family: var(--font-serif); font-size: clamp(2rem,4.5vw,3.6rem);
  font-weight: 300; line-height: 1.1; letter-spacing: -0.01em;
  color: var(--cream); margin-bottom: 1.3rem;
}
.ep-desc {
  font-family: var(--font-serif); font-size: 1.15rem; font-weight: 300;
  font-style: italic; line-height: 1.65; color: var(--linen);
  max-width: 600px; margin-bottom: 1.6rem;
}
.ep-part {
  display: inline-flex; align-items: center;
  border: 1px solid rgba(200,151,58,0.18); padding: 0.4rem 0.85rem;
  font-family: var(--font-mono); font-size: 0.58rem;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--clay);
  margin-bottom: 1.4rem;
}
.ep-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.share-btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.65rem 1.3rem; border: 1px solid var(--border);
  background: none; color: var(--fog); cursor: pointer;
  font-family: var(--font-sans); font-size: 0.6rem;
  letter-spacing: 0.13em; text-transform: uppercase;
  transition: all 0.2s;
}
.share-btn:hover { border-color: var(--amber); color: var(--amber); }
.ep-reading-bar {
  display: flex; align-items: center; padding: 0.85rem 3rem;
  background: rgba(200,151,58,0.025);
  border-bottom: 1px solid var(--border-dim);
  position: relative; z-index: 1;
}
.ep-reading-series {
  font-family: var(--font-sans); font-size: 0.58rem;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--clay);
}
#reading-pct {
  margin-left: auto; font-family: var(--font-mono);
  font-size: 0.58rem; color: var(--muted);
}
.ep-toc-wrap {
  background: rgba(200,151,58,0.03);
  border-bottom: 1px solid var(--border-dim);
  position: relative; z-index: 1;
}
.ep-toc-toggle {
  width: 100%; display: flex; align-items: center; justify-content: space-between;
  padding: 0.9rem 3rem; background: none; border: none; cursor: pointer;
}
.ep-toc-label { font-family: var(--font-sans); font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); }
.ep-toc-caret { font-size: 0.7rem; color: var(--muted); transition: transform 0.25s; }
.ep-toc-wrap.open .ep-toc-caret { transform: rotate(180deg); }
.ep-toc-list {
  display: none; list-style: none;
  padding: 0 3rem 1rem;
  border-top: 1px solid var(--border-dim);
}
.ep-toc-wrap.open .ep-toc-list { display: block; }
.ep-toc-list li { padding: 0.3rem 0; border-bottom: 1px solid var(--border-dim); }
.ep-toc-list li:last-child { border-bottom: none; }
.ep-toc-list a { font-family: var(--font-body); font-size: 1rem; color: var(--fog); transition: color 0.2s; display: block; padding: 0.1rem 0; }
.ep-toc-list a:hover { color: var(--amber); }
.ep-toc-list .toc-h3 { padding-left: 1.2rem; font-size: 0.92rem; }
.ep-layout { background: #f4ece0; min-height: 60vh; position: relative; z-index: 1; }
.ep-article {
  max-width: var(--read-w); margin: 0 auto;
  padding: 4rem 3rem; color: #1a1510;
  font-family: var(--font-body); font-size: 1.2rem; line-height: 1.95;
}
.ep-article :global(h1),
.ep-article :global(h2) {
  font-family: 'Libre Baskerville', Georgia, serif; font-weight: 700;
  color: #0d0b0a; line-height: 1.2;
}
.ep-article :global(h1) { font-size: 1.9rem; margin: 2.8rem 0 1rem; }
.ep-article :global(h2) { font-size: 1.5rem; margin: 2.5rem 0 0.9rem; }
.ep-article :global(h3) {
  font-family: var(--font-sans); font-size: 0.7rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: #8b3a1a; margin: 2rem 0 0.7rem;
}
.ep-article :global(p) { margin-bottom: 1.5rem; }
.ep-article :global(strong) { font-weight: 700; color: #0d0b0a; }
.ep-article :global(em) { font-style: italic; }
.ep-article :global(blockquote) {
  margin: 2.5rem 0; padding: 1.4rem 2rem;
  border-left: 3px solid #c8973a;
  background: rgba(200,151,58,0.06);
  font-style: italic; color: #3a2d20;
}
.ep-article :global(blockquote p) { margin: 0; }
.ep-article :global(hr) { border: none; border-top: 1px solid rgba(200,151,58,0.2); margin: 3rem 0; }
.ep-article :global(a) { color: #8b3a1a; text-decoration: underline; text-decoration-color: rgba(139,58,26,0.3); transition: color 0.2s; }
.ep-article :global(a:hover) { color: #c4622a; }
.ep-article :global(ul), .ep-article :global(ol) { padding-left: 1.8rem; margin-bottom: 1.5rem; }
.ep-article :global(li) { margin-bottom: 0.4rem; }
.ep-related { background: var(--deep); padding: 3rem; border-top: 1px solid var(--border-dim); position: relative; z-index: 1; }
.ep-related-label { font-family: var(--font-sans); font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--ember); opacity: 0.8; margin-bottom: 1.4rem; }
.ep-related-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap: 1px; }
.ep-related-card { display: block; text-decoration: none; color: inherit; background: rgba(13,17,23,0.6); border: 1px solid var(--border-dim); padding: 1.3rem; transition: background 0.2s, border-color 0.2s; }
.ep-related-card:hover { background: rgba(22,28,38,0.9); border-color: var(--border); }
.ep-related-roman { font-family: var(--font-serif); font-size: 1.5rem; font-style: italic; color: rgba(200,151,58,0.15); line-height: 1; margin-bottom: 0.4rem; }
.ep-related-tag { font-family: var(--font-sans); font-size: 0.52rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ember); opacity: 0.7; margin-bottom: 0.3rem; }
.ep-related-title { font-family: var(--font-serif); font-size: 0.95rem; font-weight: 600; color: var(--cream); line-height: 1.3; margin-bottom: 0.3rem; transition: color 0.2s; }
.ep-related-card:hover .ep-related-title { color: var(--amber); }
.ep-related-time { font-family: var(--font-mono); font-size: 0.54rem; color: var(--muted); }
.ep-nav {
  background: var(--deep); padding: 2.5rem 3rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  border-top: 1px solid var(--border-dim); position: relative; z-index: 1;
}
.ep-nav-btn { padding: 1.5rem 1.8rem; border: 1px solid var(--border-dim); text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 0.4rem; transition: background 0.2s, border-color 0.2s; border-radius: 2px; }
.ep-nav-btn:hover { background: rgba(22,28,38,0.8); border-color: var(--border); }
.ep-nav-btn.next { text-align: right; }
.ep-nav-dir { font-family: var(--font-sans); font-size: 0.55rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
.ep-nav-title { font-family: var(--font-serif); font-size: 1rem; font-style: italic; color: var(--fog); line-height: 1.3; }
#backToTop {
  position: fixed; bottom: 2rem; right: 2rem; z-index: 100;
  width: 40px; height: 40px; background: rgba(13,17,23,0.92);
  border: 1px solid var(--border); border-radius: 50%;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: var(--fog); font-size: 0.9rem;
  opacity: 0; transform: translateY(10px);
  transition: opacity 0.3s, transform 0.3s, border-color 0.2s;
  pointer-events: none;
}
#backToTop.visible { opacity: 1; transform: translateY(0); pointer-events: all; }
#backToTop:hover { border-color: var(--amber); color: var(--amber); }
@media (max-width: 768px) {
  .ep-hero { padding: 6rem 1.5rem 3rem; }
  .ep-toc-toggle { padding: 0.9rem 1.5rem; }
  .ep-toc-list { padding: 0 1.5rem 1rem; }
  .ep-reading-bar { padding: 0.7rem 1.5rem; }
  .ep-article { padding: 2.5rem 1.5rem; font-size: 1.12rem; }
  .ep-related { padding: 2rem 1.5rem; }
  .ep-nav { grid-template-columns: 1fr; padding: 1.5rem; }
}
</style>