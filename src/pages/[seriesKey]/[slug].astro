---
import Base from '../../layouts/Base.astro';
import Cosmos from '../../components/Cosmos.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { series as allSeries } from '../../data/series.js';

export async function getStaticPaths() {
  const allContent = await Astro.glob('../../content/**/*.md');
  return allContent
    .filter(p => p.frontmatter.series && !p.frontmatter.draft)
    .map(page => {
      const slug = page.file.split('/').pop().replace('.md', '');
      return { params: { seriesKey: page.frontmatter.series, slug }, props: { page } };
    });
}

const { seriesKey, slug } = Astro.params;
const { page } = Astro.props;
const fm = page.frontmatter;
const s  = allSeries[seriesKey];
const { Content } = page;

const allContent = await Astro.glob('../../content/**/*.md');
const sorted = allContent
  .filter(p => p.frontmatter.series === seriesKey && !p.frontmatter.draft)
  .sort((a, b) => (a.frontmatter.episode_number ?? 999) - (b.frontmatter.episode_number ?? 999));

const idx      = sorted.findIndex(p => p.file.split('/').pop()?.replace('.md','') === slug);
const prev     = idx > 0 ? sorted[idx - 1] : null;
const next     = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const prevSlug = prev?.file.split('/').pop()?.replace('.md','');
const nextSlug = next?.file.split('/').pop()?.replace('.md','');
const prevUrl  = prev ? `/${seriesKey}/${prevSlug}/` : undefined;
const nextUrl  = next ? `/${seriesKey}/${nextSlug}/` : undefined;

const related = sorted
  .filter(p => p.file.split('/').pop()?.replace('.md','') !== slug && p.frontmatter.part_label === fm.part_label)
  .slice(0, 3);

const raw      = typeof page.rawContent === 'function' ? page.rawContent() : '';
const words    = raw.trim().split(/\s+/).length;
const readTime = Math.max(1, Math.round(words / 230));
const dateStr  = fm.date
  ? new Date(fm.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

const siteUrl   = 'https://ishistory.pages.dev';
const canonical = `${siteUrl}/${seriesKey}/${slug}/`;

const articleLd = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: fm.title, description: fm.description ?? '',
  datePublished: fm.date ? String(fm.date) : undefined,
  author: { '@type': 'Person', name: 'Ishaan' },
  publisher: { '@type': 'Organization', name: 'ishistory', url: siteUrl },
  url: canonical, isPartOf: { '@type': 'CreativeWorkSeries', name: s.label },
};
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ishistory', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: s.label, item: `${siteUrl}/${seriesKey}/` },
    { '@type': 'ListItem', position: 3, name: fm.title, item: canonical },
  ],
};
---
<Base
  title={`${fm.title} — ishistory`}
  description={fm.description ?? ''}
  ogType="article"
  publishedTime={fm.date ? String(fm.date) : undefined}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}></script>
</Fragment>

<div id="progress-bar" aria-hidden="true"></div>
<Cosmos />
<Nav backLink={{ href: `/${seriesKey}/`, label: s.shortLabel }} />

<section class="ep-hero">
  <div class="ep-hero-numeral" aria-hidden="true">{fm.roman}</div>
  <div class="ep-hero-inner">
    <div class="ep-meta">
      {fm.roman && <span class="ep-episode">Episode {fm.roman}</span>}
      {fm.roman && <span class="ep-sep" aria-hidden="true">·</span>}
      {fm.tag   && <span class="ep-tag">{fm.tag}</span>}
      {dateStr  && <time class="ep-date" datetime={String(fm.date)}>{dateStr}</time>}
      <span class="ep-time">{readTime} min read</span>
    </div>
    <h1 class="ep-title">{fm.title}</h1>
    {fm.description && <p class="ep-desc">{fm.description}</p>}
    {fm.part_label  && <div class="ep-part">{fm.part_label}</div>}
    <div class="ep-actions">
      <button class="share-btn" id="shareBtn">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><circle cx="10.5" cy="2.5" r="1.5" stroke="currentColor" stroke-width="1.1"/><circle cx="2.5" cy="6.5" r="1.5" stroke="currentColor" stroke-width="1.1"/><circle cx="10.5" cy="10.5" r="1.5" stroke="currentColor" stroke-width="1.1"/><line x1="4" y1="5.8" x2="9" y2="3.2" stroke="currentColor" stroke-width="1.1"/><line x1="4" y1="7.2" x2="9" y2="9.8" stroke="currentColor" stroke-width="1.1"/></svg>
        Share
      </button>
    </div>
  </div>
</section>

<div class="ep-reading-strip">
  <span class="ep-reading-series">{s.label}</span>
  <span class="ep-reading-sep" aria-hidden="true">·</span>
  <span class="ep-reading-title">{fm.title}</span>
  <span id="reading-pct" class="ep-reading-pct" aria-live="polite">0%</span>
</div>

<div class="ep-toc-wrap" id="tocWrap" style="display:none">
  <button class="ep-toc-toggle" id="tocToggle" aria-expanded="false">
    <span class="ep-toc-label">Contents</span>
    <svg class="ep-toc-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <ul class="ep-toc-list" id="tocList" role="list"></ul>
</div>

<div class="ep-layout">
  <article class="ep-article" id="epArticle">
    <Content />
  </article>
</div>

{related.length > 0 && (
  <div class="ep-related">
    <p class="ep-related-label">Also in this part</p>
    <div class="ep-related-grid">
      {related.map(r => {
        const rSlug  = r.file.split('/').pop()?.replace('.md','');
        const rWords = typeof r.rawContent === 'function' ? r.rawContent().trim().split(/\s+/).length : 0;
        const rTime  = Math.max(1, Math.round(rWords / 230));
        return (
          <a href={`/${seriesKey}/${rSlug}/`} class="ep-related-card">
            <div class="ep-related-roman" aria-hidden="true">{r.frontmatter.roman}</div>
            <div class="ep-related-tag">{r.frontmatter.tag ?? 'Episode'}</div>
            <div class="ep-related-title">{r.frontmatter.title}</div>
            <div class="ep-related-time">{rTime} min</div>
          </a>
        );
      })}
    </div>
  </div>
)}

<nav class="ep-nav" aria-label="Episode navigation">
  {prev ? (
    <a href={prevUrl} class="ep-nav-btn prev">
      <span class="ep-nav-dir">← Previous</span>
      <span class="ep-nav-title">{prev.frontmatter.title}</span>
    </a>
  ) : <div></div>}
  {next ? (
    <a href={nextUrl} class="ep-nav-btn next">
      <span class="ep-nav-dir">Next →</span>
      <span class="ep-nav-title">{next.frontmatter.title}</span>
    </a>
  ) : <div></div>}
</nav>

<Footer />
<button id="backToTop" aria-label="Back to top">↑</button>

<script define:vars={{ prevUrl, nextUrl, slug, seriesKey }}>
  const bar     = document.getElementById('progress-bar');
  const pct     = document.getElementById('reading-pct');
  const article = document.getElementById('epArticle');
  const topBtn  = document.getElementById('backToTop');
  window.addEventListener('scroll', () => {
    if (!article) return;
    const total = article.offsetHeight - window.innerHeight;
    const p = Math.round(Math.max(0, Math.min(1, -article.getBoundingClientRect().top / total)) * 100);
    if (bar) bar.style.width = p + '%';
    if (pct) pct.textContent = p + '%';
    if (topBtn) topBtn.classList.toggle('visible', window.scrollY > 500);
  }, { passive: true });
  topBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  localStorage.setItem('read:' + seriesKey + ':' + slug, '1');
  const headings  = article?.querySelectorAll('h2, h3');
  const tocWrap   = document.getElementById('tocWrap');
  const tocList   = document.getElementById('tocList');
  const tocToggle = document.getElementById('tocToggle');
  if (headings && headings.length >= 3 && tocWrap && tocList) {
    tocWrap.style.display = 'block';
    headings.forEach((h, i) => {
      if (!h.id) h.id = 'h-' + i;
      const li = document.createElement('li');
      if (h.tagName === 'H3') li.classList.add('toc-h3');
      const a = document.createElement('a');
      a.href = '#' + h.id; a.textContent = h.textContent ?? '';
      a.addEventListener('click', e => {
        e.preventDefault();
        h.scrollIntoView({ behavior: 'smooth', block: 'start' });
        tocWrap.classList.remove('open');
        tocToggle?.setAttribute('aria-expanded', 'false');
      });
      li.appendChild(a); tocList.appendChild(li);
    });
    tocToggle?.addEventListener('click', () => {
      const open = tocWrap.classList.toggle('open');
      tocToggle.setAttribute('aria-expanded', String(open));
    });
  }
  const shareBtn = document.getElementById('shareBtn');
  shareBtn?.addEventListener('click', async () => {
    try {
      if (navigator.share) { await navigator.share({ title: document.title, url: window.location.href }); }
      else {
        await navigator.clipboard.writeText(window.location.href);
        const orig = shareBtn.innerHTML;
        shareBtn.textContent = 'Copied!';
        setTimeout(() => { shareBtn.innerHTML = orig; }, 2000);
      }
    } catch(e) {}
  });
  document.addEventListener('keydown', e => {
    if (e.altKey || e.ctrlKey || e.metaKey) return;
    if (e.key === 'ArrowLeft'  && prevUrl) window.location.href = prevUrl;
    if (e.key === 'ArrowRight' && nextUrl) window.location.href = nextUrl;
  });
</script>
</Base>

<style>
#progress-bar { position: fixed; top: 0; left: 0; height: 2px; background: var(--amber); width: 0%; z-index: 999; transition: width 0.1s linear; box-shadow: 0 0 10px rgba(200,151,58,0.45); }
.ep-hero { padding: calc(var(--nav-h) + 4.5rem) 3rem 4rem; background: linear-gradient(160deg, var(--ink) 0%, var(--deep) 60%, var(--ink) 100%); position: relative; overflow: hidden; z-index: 1; border-bottom: 1px solid var(--border-dim); }
.ep-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 55% 65% at 80% 50%, rgba(200,151,58,0.055) 0%, transparent 60%); pointer-events: none; }
.ep-hero-numeral { position: absolute; right: 3%; top: 50%; transform: translateY(-50%); font-family: var(--font-serif); font-size: clamp(9rem,16vw,18rem); font-weight: 300; color: rgba(200,151,58,0.04); line-height: 1; pointer-events: none; user-select: none; }
.ep-hero-inner { position: relative; max-width: 780px; opacity: 0; animation: fadeUp 0.8s 0.1s ease forwards; }
.ep-meta { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.6rem; flex-wrap: wrap; }
.ep-episode { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber); }
.ep-sep { color: var(--border); }
.ep-tag { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fog); background: rgba(200,151,58,0.08); padding: 0.2rem 0.65rem; border: 1px solid rgba(200,151,58,0.12); }
.ep-date { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.08em; color: var(--fog); }
.ep-time { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.08em; color: var(--muted); }
.ep-title { font-family: var(--font-serif); font-size: clamp(2.2rem,5vw,4rem); font-weight: 300; line-height: 1.08; letter-spacing: -0.015em; color: var(--cream); margin-bottom: 1.4rem; }
.ep-desc { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 300; font-style: italic; line-height: 1.7; color: var(--linen); max-width: 58ch; margin-bottom: 1.6rem; }
.ep-part { display: inline-flex; align-items: center; border: 1px solid rgba(200,151,58,0.18); padding: 0.38rem 0.85rem; font-family: var(--font-mono); font-size: 0.57rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--clay); margin-bottom: 1.6rem; }
.ep-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
.share-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.25rem; border: 1px solid var(--border); background: none; color: var(--fog); cursor: pointer; font-family: var(--font-sans); font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase; transition: border-color var(--t-fast), color var(--t-fast); border-radius: 1px; }
.share-btn:hover { border-color: var(--amber); color: var(--amber); }
.ep-reading-strip { display: flex; align-items: center; gap: 0.7rem; padding: 0.75rem 3rem; background: rgba(200,151,58,0.025); border-bottom: 1px solid var(--border-dim); position: sticky; top: var(--nav-h); z-index: 50; backdrop-filter: blur(8px); }
.ep-reading-series { font-family: var(--font-sans); font-size: 0.56rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--clay); white-space: nowrap; }
.ep-reading-sep { color: var(--border); font-size: 0.7rem; }
.ep-reading-title { font-family: var(--font-body); font-size: 0.88rem; font-style: italic; color: var(--dust); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
.ep-reading-pct { font-family: var(--font-mono); font-size: 0.56rem; color: var(--muted); margin-left: auto; white-space: nowrap; }
.ep-toc-wrap { background: rgba(200,151,58,0.02); border-bottom: 1px solid var(--border-dim); position: relative; z-index: 1; }
.ep-toc-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 3rem; background: none; border: none; cursor: pointer; gap: 1rem; }
.ep-toc-label { font-family: var(--font-sans); font-size: 0.58rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--amber); }
.ep-toc-caret { color: var(--muted); transition: transform 0.25s ease; flex-shrink: 0; }
.ep-toc-wrap.open .ep-toc-caret { transform: rotate(180deg); }
.ep-toc-list { display: none; list-style: none; padding: 0 3rem 1.2rem; border-top: 1px solid var(--border-dim); }
.ep-toc-wrap.open .ep-toc-list { display: block; }
.ep-toc-list li { border-bottom: 1px solid var(--border-dim); }
.ep-toc-list li:last-child { border-bottom: none; }
.ep-toc-list a { display: block; padding: 0.5rem 0; font-family: var(--font-body); font-size: 1rem; color: var(--fog); transition: color var(--t-fast), padding-left var(--t-fast); }
.ep-toc-list a:hover { color: var(--amber); padding-left: 0.4rem; }
.ep-toc-list .toc-h3 a { padding-left: 1.2rem; font-size: 0.92rem; color: var(--dust); }
.ep-toc-list .toc-h3 a:hover { padding-left: 1.5rem; color: var(--amber); }
.ep-layout { background: #f5ece0; position: relative; z-index: 1; }
.ep-article { max-width: var(--read-w); margin: 0 auto; padding: 4.5rem 3rem 5rem; color: #1c1208; font-family: var(--font-body); font-size: 1.22rem; line-height: 2; }
.ep-article :global(p) { margin-bottom: 1.6em; }
.ep-article :global(h2) { font-family: var(--font-serif); font-size: 1.7rem; font-weight: 700; color: #0d0a06; line-height: 1.2; margin: 3rem 0 1.1rem; letter-spacing: -0.01em; }
.ep-article :global(h3) { font-family: var(--font-sans); font-size: 0.67rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: #8b3a1a; margin: 2.5rem 0 0.8rem; }
.ep-article :global(h4) { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; font-style: italic; color: #2a1a0a; margin: 2rem 0 0.6rem; }
.ep-article :global(strong) { font-weight: 700; color: #0d0a06; }
.ep-article :global(em) { font-style: italic; }
.ep-article :global(blockquote) { margin: 2.8rem 0; padding: 1.5rem 2rem; border-left: 3px solid #c8973a; background: rgba(200,151,58,0.06); font-style: italic; color: #3a2a18; border-radius: 0 2px 2px 0; }
.ep-article :global(blockquote p) { margin: 0; }
.ep-article :global(hr) { border: none; border-top: 1px solid rgba(200,151,58,0.25); margin: 3.5rem auto; width: 60%; }
.ep-article :global(a) { color: #8b3a1a; text-decoration: underline; text-decoration-color: rgba(139,58,26,0.3); text-underline-offset: 2px; transition: color 0.15s, text-decoration-color 0.15s; }
.ep-article :global(a:hover) { color: #c4622a; text-decoration-color: rgba(196,98,42,0.5); }
.ep-article :global(ul), .ep-article :global(ol) { padding-left: 1.8rem; margin-bottom: 1.6em; }
.ep-article :global(li) { margin-bottom: 0.45em; }
.ep-article :global(code) { font-family: var(--font-mono); font-size: 0.88em; background: rgba(200,151,58,0.12); padding: 0.1em 0.4em; border-radius: 2px; color: #6b2e0a; }
.ep-related { background: var(--deep); padding: 3.5rem 3rem; border-top: 1px solid var(--border-dim); position: relative; z-index: 1; }
.ep-related-label { font-family: var(--font-sans); font-size: 0.58rem; letter-spacing: 0.26em; text-transform: uppercase; color: var(--ember); display: flex; align-items: center; gap: 1rem; margin-bottom: 1.8rem; }
.ep-related-label::before { content: ''; width: 18px; height: 1px; background: var(--ember); opacity: 0.6; }
.ep-related-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap: 1px; background: var(--border-dim); }
.ep-related-card { display: flex; flex-direction: column; gap: 0.4rem; text-decoration: none; color: inherit; background: var(--deep); border: 1px solid transparent; padding: 1.4rem 1.3rem; transition: background var(--t-base), border-color var(--t-base); }
.ep-related-card:hover { background: var(--surface); border-color: var(--border); }
.ep-related-roman { font-family: var(--font-serif); font-size: 1.6rem; font-style: italic; color: rgba(200,151,58,0.15); line-height: 1; margin-bottom: 0.2rem; user-select: none; }
.ep-related-tag { font-family: var(--font-sans); font-size: 0.5rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ember); opacity: 0.7; }
.ep-related-title { font-family: var(--font-serif); font-size: 0.97rem; font-weight: 600; color: var(--cream); line-height: 1.3; transition: color var(--t-fast); }
.ep-related-card:hover .ep-related-title { color: var(--amber); }
.ep-related-time { font-family: var(--font-mono); font-size: 0.54rem; color: var(--muted); margin-top: 0.2rem; }
.ep-nav { background: var(--border-dim); padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1px; border-top: 1px solid var(--border-dim); position: relative; z-index: 1; }
.ep-nav-btn { padding: 1.6rem 2rem; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 0.5rem; background: var(--deep); transition: background var(--t-base); }
.ep-nav-btn:hover { background: var(--surface); }
.ep-nav-btn.next { text-align: right; }
.ep-nav-dir { font-family: var(--font-sans); font-size: 0.54rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); transition: color var(--t-fast); }
.ep-nav-btn:hover .ep-nav-dir { color: var(--amber); }
.ep-nav-title { font-family: var(--font-serif); font-size: 1.05rem; font-style: italic; color: var(--fog); line-height: 1.3; transition: color var(--t-fast); }
.ep-nav-btn:hover .ep-nav-title { color: var(--cream); }
#backToTop { position: fixed; bottom: 2rem; right: 2rem; z-index: 100; width: 40px; height: 40px; background: rgba(12,15,22,0.92); border: 1px solid var(--border); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--fog); font-size: 0.9rem; opacity: 0; transform: translateY(10px); transition: opacity 0.3s, transform 0.3s, border-color var(--t-fast), color var(--t-fast); pointer-events: none; }
#backToTop.visible { opacity: 1; transform: translateY(0); pointer-events: all; }
#backToTop:hover { border-color: var(--amber); color: var(--amber); }
@media (max-width: 768px) { .ep-hero { padding: calc(var(--nav-h) + 2.5rem) 1.5rem 3rem; } .ep-reading-strip { padding: 0.65rem 1.5rem; } .ep-reading-title { display: none; } .ep-toc-toggle { padding: 0.85rem 1.5rem; } .ep-toc-list { padding: 0 1.5rem 1rem; } .ep-article { padding: 2.5rem 1.5rem 4rem; font-size: 1.12rem; line-height: 1.9; } .ep-related { padding: 2.5rem 1.5rem; } .ep-nav { grid-template-columns: 1fr; } .ep-nav-btn { padding: 1.4rem 1.5rem; } }
</style>
