---
import Base from '../../layouts/Base.astro';
import Cosmos from '../../components/Cosmos.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { series as allSeries } from '../../data/series.js';
import { siteUrl } from '../../data/config.js';

export function getStaticPaths() {
  return Object.keys(allSeries).map(key => ({ params: { seriesKey: key } }));
}

const { seriesKey } = Astro.params;
const s = allSeries[seriesKey];

const allContent = await Astro.glob('../../content/**/*.md');
const pages = allContent
  .filter(p => p.frontmatter.series === seriesKey && !p.frontmatter.draft)
  .sort((a, b) => (a.frontmatter.episode_number ?? 999) - (b.frontmatter.episode_number ?? 999));

const episodes = pages.filter(p => p.frontmatter.type !== 'profile');
const profiles  = pages.filter(p => p.frontmatter.type === 'profile');

const partMap = new Map();
const partOrder = [];
for (const page of episodes) {
  const pl = page.frontmatter.part_label ?? 'Episodes';
  if (!partMap.has(pl)) { partMap.set(pl, []); partOrder.push(pl); }
  partMap.get(pl).push(page);
}

const otherSeries = Object.entries(allSeries).filter(([k]) => k !== seriesKey);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ishistory', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: s.label, item: `${siteUrl}/${seriesKey}/` },
  ],
};
---
<Base title={`${s.label} — ishistory`} description={s.longDescription ?? s.description}>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
</Fragment>

<Cosmos />
<Nav activeSection={`/${seriesKey}/`} />

<section class="hero" style={`--c: ${s.color}`}>
  <div class="hero-glyph" aria-hidden="true">{s.glyph}</div>
  <div class="hero-content">
    <p class="hero-breadcrumb">
      <a href="/">ishistory</a>
      <span aria-hidden="true">/</span>
      {s.shortLabel}
    </p>
    <p class="hero-eyebrow">ishistory Series</p>
    <h1 class="hero-title">{s.label}</h1>
    <p class="hero-desc">{s.description}</p>
    <div class="hero-stats">
      <div class="stat"><div class="stat-n">{episodes.length}</div><div class="stat-l">Episodes</div></div>
      {profiles.length > 0 && <div class="stat"><div class="stat-n">{profiles.length}</div><div class="stat-l">Profiles</div></div>}
      {partOrder.length > 1 && <div class="stat"><div class="stat-n">{partOrder.length}</div><div class="stat-l">Parts</div></div>}
      {s.status === 'complete' && <div class="stat"><div class="stat-n">✓</div><div class="stat-l">Complete</div></div>}
    </div>
    <div class="hero-cta">
      <a href="#episodes" class="btn btn-primary">Start Reading</a>
      <a href="/search/" class="btn btn-secondary">Search Episodes</a>
    </div>
  </div>
</section>

<div class="divider"><div class="divider-line"></div><div class="divider-sym">…</div><div class="divider-line"></div></div>

<section class="episodes" id="episodes">
  {partOrder.map((pl, pi) => {
    const eps   = partMap.get(pl);
    const sub   = pl.replace(/Part\s+[IVX\d]+\s*[\u00b7:\s]?\s*/i, '').trim();
    const rm    = pl.match(/Part\s+([IVX]+)/i);
    const pRoman = rm ? rm[1] : String(pi + 1);
    return (
      <div class="part">
        <div class="part-header">
          <div class="part-roman" aria-hidden="true">{pRoman}</div>
          <div class="part-info">
            <div class="part-meta">Part {pi + 1} of {partOrder.length} · {eps.length} episodes</div>
            <div class="part-title">{sub || pl}</div>
          </div>
        </div>
        <div class="ep-list">
          {eps.map(page => {
            const fm   = page.frontmatter;
            const slug = page.file.split('/').pop()?.replace('.md', '') ?? '';
            const words = typeof page.rawContent === 'function' ? page.rawContent().trim().split(/\s+/).length : 0;
            const time  = Math.max(1, Math.round(words / 230));
            return (
              <a href={`/${seriesKey}/${slug}/`} class="ep-card" data-read-key={`read:${seriesKey}:${slug}`}>
                <div class="ep-card-num">{fm.roman}</div>
                <div class="ep-card-body">
                  <div class="ep-card-tag">{fm.tag ?? 'Episode'}</div>
                  <div class="ep-card-title">{fm.title}</div>
                  {fm.description && <div class="ep-card-desc">{fm.description}</div>}
                  <div class="ep-card-time">{time} min read</div>
                </div>
                <div class="ep-card-arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    );
  })}
</section>

{otherSeries.length > 0 && (
  <section class="other-series">
    <div class="other-series-inner">
      <p class="other-series-label">More from ishistory</p>
      <div class="other-series-grid">
        {otherSeries.map(([key, os]) => (
          <a href={`/${key}/`} class="other-card">
            <div class="other-card-glyph">{os.glyph}</div>
            <div class="other-card-label">Series</div>
            <div class="other-card-title">{os.label}</div>
            <p class="other-card-desc">{os.description}</p>
            <span class="other-card-link">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<Footer />

<script>
  document.querySelectorAll('.ep-card[data-read-key]').forEach(card => {
    const key = card.getAttribute('data-read-key');
    if (key && localStorage.getItem(key)) card.classList.add('is-read');
  });
</script>
</Base>

<style>
.hero { min-height: 72vh; display: flex; flex-direction: column; justify-content: center; padding: calc(var(--nav-h) + 5rem) 3rem 5rem; position: relative; z-index: 1; overflow: hidden; border-bottom: 1px solid var(--border-dim); }
.hero::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 70% at 75% 50%, rgba(200,151,58,0.05) 0%, transparent 65%); pointer-events: none; }
.hero-glyph { position: absolute; right: 2%; top: 50%; transform: translateY(-48%); font-family: var(--font-mono); font-size: clamp(10rem,18vw,22rem); font-weight: 400; color: rgba(200,151,58,0.04); line-height: 1; pointer-events: none; user-select: none; letter-spacing: -0.05em; }
.hero-content { position: relative; z-index: 1; max-width: 740px; }
.hero-breadcrumb { font-family: var(--font-sans); font-size: 0.57rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dust); margin-bottom: 1.6rem; display: flex; align-items: center; gap: 0.7rem; opacity: 0; animation: fadeUp 0.7s 0.1s ease forwards; }
.hero-breadcrumb a { color: var(--fog); transition: color 0.15s; }
.hero-breadcrumb a:hover { color: var(--amber); }
.hero-breadcrumb span { opacity: 0.3; }
.hero-eyebrow { font-family: var(--font-sans); font-size: 0.6rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--ember); margin-bottom: 1.2rem; display: flex; align-items: center; gap: 1.2rem; opacity: 0; animation: fadeUp 0.8s 0.22s ease forwards; }
.hero-eyebrow::before { content: ''; width: 26px; height: 1px; background: var(--ember); opacity: 0.7; flex-shrink: 0; }
.hero-title { font-family: var(--font-serif); font-size: clamp(2.8rem,6.5vw,6rem); font-weight: 700; line-height: 0.93; letter-spacing: -0.025em; color: var(--cream); margin-bottom: 1.5rem; opacity: 0; animation: fadeUp 1s 0.34s ease forwards; }
.hero-desc { font-family: var(--font-body); font-size: 1.15rem; line-height: 1.85; color: var(--fog); max-width: 52ch; font-style: italic; margin-bottom: 2.2rem; opacity: 0; animation: fadeUp 0.9s 0.5s ease forwards; }
.hero-stats { display: flex; gap: 2.8rem; margin-bottom: 2.2rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.8s 0.6s ease forwards; }
.stat-n { font-family: var(--font-serif); font-size: 2.2rem; font-style: italic; color: var(--amber); line-height: 1; }
.stat-l { font-family: var(--font-sans); font-size: 0.54rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dust); margin-top: 0.25rem; }
.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.9s 0.7s ease forwards; }
.episodes { padding: 3rem 3rem 7rem; max-width: var(--max-w); margin: 0 auto; position: relative; z-index: 1; }
.part { margin-bottom: 4.5rem; }
.part-header { display: flex; align-items: center; gap: 1.8rem; padding-bottom: 1.2rem; margin-bottom: 0; border-bottom: 1px solid var(--border-dim); }
.part-roman { font-family: var(--font-serif); font-size: 3rem; font-style: italic; font-weight: 300; color: rgba(200,151,58,0.1); line-height: 1; flex-shrink: 0; min-width: 3rem; user-select: none; }
.part-meta { font-family: var(--font-sans); font-size: 0.54rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dust); margin-bottom: 0.3rem; }
.part-title { font-family: var(--font-serif); font-size: 1.15rem; font-style: italic; font-weight: 300; color: var(--fog); line-height: 1.3; }
.ep-list { display: flex; flex-direction: column; }
.ep-card { display: grid; grid-template-columns: 3rem 1fr auto; align-items: start; gap: 1.2rem 1.4rem; padding: 1.4rem 1.2rem 1.4rem 0; border-bottom: 1px solid var(--border-dim); text-decoration: none; color: inherit; transition: background var(--t-base), padding-left var(--t-base); position: relative; }
.ep-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--amber); transform: scaleY(0); transform-origin: bottom; transition: transform 0.3s ease; }
.ep-card:hover { background: rgba(200,151,58,0.025); padding-left: 1.2rem; }
.ep-card:hover::before { transform: scaleY(1); }
.ep-card.is-read .ep-card-title::after { content: ' ✓'; font-family: var(--font-sans); font-size: 0.55rem; color: var(--amber); opacity: 0.5; vertical-align: middle; margin-left: 0.4rem; }
.ep-card-num { font-family: var(--font-serif); font-size: 1.5rem; font-style: italic; font-weight: 300; color: rgba(200,151,58,0.18); line-height: 1; padding-top: 0.2rem; user-select: none; text-align: right; }
.ep-card-tag { font-family: var(--font-sans); font-size: 0.52rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ember); margin-bottom: 0.35rem; opacity: 0.75; }
.ep-card-title { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 600; color: var(--cream); margin-bottom: 0.4rem; line-height: 1.25; transition: color var(--t-fast); }
.ep-card:hover .ep-card-title { color: var(--amber); }
.ep-card-desc { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.65; color: var(--fog); margin-bottom: 0.5rem; }
.ep-card-time { font-family: var(--font-mono); font-size: 0.57rem; letter-spacing: 0.08em; color: var(--muted); }
.ep-card-arrow { color: rgba(200,151,58,0.18); align-self: center; transition: color var(--t-fast), transform var(--t-base); flex-shrink: 0; padding-top: 0.1rem; }
.ep-card:hover .ep-card-arrow { color: var(--amber); transform: translateX(3px); }
.other-series { border-top: 1px solid var(--border-dim); background: var(--deep); position: relative; z-index: 1; }
.other-series-inner { max-width: var(--max-w); margin: 0 auto; padding: 4rem 3rem; }
.other-series-label { font-family: var(--font-sans); font-size: 0.58rem; letter-spacing: 0.26em; text-transform: uppercase; color: var(--ember); display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
.other-series-label::before { content: ''; width: 20px; height: 1px; background: var(--ember); opacity: 0.6; }
.other-series-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(260px,1fr)); gap: 1px; background: var(--border-dim); }
.other-card { display: flex; flex-direction: column; gap: 0.6rem; padding: 2rem 2rem 1.6rem; background: var(--deep); text-decoration: none; color: inherit; transition: background var(--t-base); position: relative; overflow: hidden; }
.other-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--amber); transform: scaleY(0); transform-origin: bottom; transition: transform 0.3s ease; }
.other-card:hover { background: var(--surface); }
.other-card:hover::before { transform: scaleY(1); }
.other-card-glyph { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; color: var(--amber); opacity: 0.4; margin-bottom: 0.4rem; transition: opacity var(--t-base); }
.other-card:hover .other-card-glyph { opacity: 0.8; }
.other-card-label { font-family: var(--font-sans); font-size: 0.52rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ember); opacity: 0.7; }
.other-card-title { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 700; font-style: italic; color: var(--cream); line-height: 1.2; transition: color var(--t-fast); }
.other-card:hover .other-card-title { color: var(--amber); }
.other-card-desc { font-family: var(--font-body); font-size: 0.93rem; line-height: 1.65; color: var(--fog); flex: 1; }
.other-card-link { font-family: var(--font-sans); font-size: 0.55rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--dust); margin-top: 0.4rem; transition: color var(--t-fast); }
.other-card:hover .other-card-link { color: var(--amber); }
@media (max-width: 768px) { .hero { padding: calc(var(--nav-h) + 3rem) 1.5rem 4rem; } .hero-stats { gap: 1.8rem; } .episodes { padding: 2rem 1.5rem 5rem; } .ep-card { grid-template-columns: 2.5rem 1fr auto; gap: 0.8rem 1rem; } .other-series-inner { padding: 3rem 1.5rem; } .other-series-grid { grid-template-columns: 1fr; } }
</style>
