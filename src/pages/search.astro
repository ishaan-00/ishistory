---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cosmos from '../components/Cosmos.astro';
---
<Base title="Search — ishistory" description="Search all episodes across every ishistory series.">
<Cosmos />
<Nav />
<section class="search-hero">
  <h1 class="search-title">Search</h1>
  <p class="search-sub">Search across all episodes and series</p>
  <div class="search-box-wrap">
    <input type="search" id="searchInput" placeholder="Search episodes, topics, people…" autocomplete="off" autofocus />
    <span class="search-icon">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
        <line x1="11" y1="11" x2="15" y2="15" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </span>
  </div>
  <div class="search-filters" id="searchFilters">
    <button class="filter-btn active" data-series="">All</button>
    <button class="filter-btn" data-series="ai-history">AI History</button>
    <button class="filter-btn" data-series="internet-history">Internet History</button>
    <button class="filter-btn" data-series="robotics">Robotics</button>
  </div>
</section>
<section class="search-results" id="searchResults">
  <p class="search-hint" id="searchHint">Start typing to search episodes…</p>
</section>
<Footer />
</Base>

<script>
let index = null;
let activeSeries = '';

async function loadIndex() {
  if (index) return index;
  const res = await fetch('/search-index.json');
  index = await res.json();
  return index;
}

function highlight(text, query) {
  if (!query) return text;
  const re = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  return text.replace(re, '<mark>$1</mark>');
}

async function doSearch(query) {
  const hint    = document.getElementById('searchHint');
  const results = document.getElementById('searchResults');
  if (!query || query.length < 2) {
    hint.style.display = 'block'; hint.textContent = 'Start typing to search episodes…';
    results.querySelectorAll('.result-card').forEach(el => el.remove());
    return;
  }
  hint.style.display = 'none';
  const data = await loadIndex();
  const q    = query.toLowerCase();
  const hits = data.filter(item => {
    if (activeSeries && item.series !== activeSeries) return false;
    return item.title.toLowerCase().includes(q)
      || (item.description || '').toLowerCase().includes(q)
      || (item.body || '').toLowerCase().includes(q);
  });
  results.querySelectorAll('.result-card').forEach(el => el.remove());
  if (hits.length === 0) {
    hint.style.display = 'block'; hint.textContent = `No results for "${query}"`;
    return;
  }
  hits.slice(0, 20).forEach(item => {
    const card = document.createElement('a');
    card.className = 'result-card';
    card.href = item.url;
    const bodySnippet = (item.body || '').toLowerCase().indexOf(q);
    const snippet = bodySnippet >= 0
      ? '…' + item.body.slice(Math.max(0, bodySnippet - 60), bodySnippet + 120) + '…'
      : item.description || '';
    card.innerHTML = `
      <div class="result-series">${item.seriesLabel}</div>
      <div class="result-title">${highlight(item.title, query)}</div>
      <div class="result-snippet">${highlight(snippet, query)}</div>
      <div class="result-meta">${item.readTime ? item.readTime + ' min read' : ''}</div>
    `;
    results.appendChild(card);
  });
}

const input = document.getElementById('searchInput');
let timer;
input?.addEventListener('input', () => {
  clearTimeout(timer);
  timer = setTimeout(() => doSearch(input.value.trim()), 200);
});

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeSeries = btn.dataset.series;
    doSearch(input?.value.trim() || '');
  });
});

// Keyboard shortcut: / to focus search
document.addEventListener('keydown', e => {
  if (e.key === '/' && document.activeElement !== input) {
    e.preventDefault(); input?.focus();
  }
  if (e.key === 'Escape') input?.blur();
});
</script>

<style>
.search-hero {
  padding: 8rem 3rem 3rem; max-width: 720px; margin: 0 auto;
  position: relative; z-index: 1;
}
.search-title {
  font-family: var(--font-serif); font-size: clamp(2.5rem,6vw,4.5rem);
  font-weight: 300; font-style: italic; color: var(--cream);
  margin-bottom: 0.5rem;
}
.search-sub {
  font-family: var(--font-body); font-size: 1rem;
  color: var(--fog); font-style: italic; margin-bottom: 2rem;
}
.search-box-wrap {
  position: relative; margin-bottom: 1.4rem;
}
#searchInput {
  width: 100%; padding: 1rem 3rem 1rem 1.4rem;
  background: var(--surface); border: 1px solid var(--border);
  color: var(--cream); font-family: var(--font-body); font-size: 1.1rem;
  outline: none; transition: border-color 0.2s;
}
#searchInput:focus { border-color: var(--amber); }
#searchInput::placeholder { color: var(--muted); }
.search-icon {
  position: absolute; right: 1rem; top: 50%; transform: translateY(-50%);
  color: var(--muted); pointer-events: none;
}
.search-filters {
  display: flex; gap: 0.5rem; flex-wrap: wrap;
}
.filter-btn {
  font-family: var(--font-sans); font-size: 0.58rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.4rem 0.9rem; border: 1px solid var(--border-dim);
  background: none; color: var(--fog); cursor: pointer;
  transition: all 0.15s;
}
.filter-btn:hover, .filter-btn.active {
  border-color: var(--amber); color: var(--amber);
  background: rgba(200,151,58,0.06);
}
.search-results {
  max-width: 720px; margin: 0 auto; padding: 1rem 3rem 6rem;
  position: relative; z-index: 1; display: flex; flex-direction: column; gap: 1px;
}
.search-hint {
  font-family: var(--font-body); font-size: 1rem;
  color: var(--muted); font-style: italic; padding: 2rem 0;
}
.result-card {
  display: block; text-decoration: none; color: inherit;
  background: rgba(13,17,23,0.5); border: 1px solid var(--border-dim);
  padding: 1.4rem 1.6rem; transition: background 0.2s, border-color 0.2s;
}
.result-card:hover { background: rgba(22,28,38,0.9); border-color: var(--border); }
.result-series { font-family: var(--font-sans); font-size: 0.55rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ember); margin-bottom: 0.35rem; opacity: 0.8; }
.result-title { font-family: var(--font-serif); font-size: 1.15rem; font-weight: 600; color: var(--cream); margin-bottom: 0.4rem; transition: color 0.2s; }
.result-card:hover .result-title { color: var(--amber); }
.result-snippet { font-family: var(--font-body); font-size: 0.95rem; line-height: 1.65; color: var(--fog); margin-bottom: 0.4rem; }
.result-snippet :global(mark) { background: rgba(200,151,58,0.2); color: var(--cream); border-radius: 1px; }
.result-meta { font-family: var(--font-mono); font-size: 0.55rem; color: var(--muted); }
@media (max-width: 768px) {
  .search-hero, .search-results { padding-left: 1.5rem; padding-right: 1.5rem; }
}
</style>